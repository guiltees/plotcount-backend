# ─── PlotCount AI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.

# Google Maps API key (required for source=map and source=kml)
# Restrict this key to "Maps Static API" in the Google Cloud console.
# For Android: restrict by SHA-1 + package name.
GOOGLE_MAPS_API_KEY=AIzaSyDjOsph-DQRqxa5JkwwknL9ZVm_nkKGVzM

# YOLO model weights file path (default: auto-downloaded yolov8n-seg.pt)
YOLO_WEIGHTS=yolov8n-seg.pt

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Max image edge size in pixels (resize larger images before inference)
MAX_IMAGE_EDGE=1024
